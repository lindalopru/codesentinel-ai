# Copy to .env and edit as needed. All values shown are defaults.

# Ollama server (default localhost listener)
OLLAMA_HOST=http://127.0.0.1:11434

# Primary model (must be pulled with: ollama pull qwen2.5-coder:7b-instruct-q4_K_M)
OLLAMA_MODEL=qwen2.5-coder:7b-instruct-q4_K_M

# Context window — Ollama default is 2048 which silently truncates files.
OLLAMA_NUM_CTX=16384

# Generation params
OLLAMA_TEMPERATURE=0.2
OLLAMA_TOP_P=0.9
OLLAMA_TIMEOUT=180

# Engine knobs
MAX_FILE_LINES=1500
CONCURRENCY=2
ENABLE_BANDIT=true
ENABLE_RUFF=true
ENABLE_ESLINT=true
